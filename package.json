{
  "name": "dev",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "ng lint",
    "lint:server": "eslint server/**/*.ts",
    "lint:all": "npm run lint && npm run lint:server",
    "format": "prettier --write \"src/**/*.{ts,html}\" \"server/**/*.ts\" \"e2e/**/*.ts\" \"playwright/**/*.ts\" \"cypress.config.ts\" \"playwright.config.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,html}\" \"server/**/*.ts\" \"e2e/**/*.ts\" \"playwright/**/*.ts\" \"cypress.config.ts\" \"playwright.config.ts\"",
    "lint:fix": "ng lint --fix && npm run format",
    "lint:fix:server": "eslint server/**/*.ts --fix && npm run format",
    "lint:fix:all": "npm run lint:fix && npm run lint:fix:server",
    "storybook": "ng run dev:storybook",
    "build-storybook": "ng run dev:build-storybook",
    "e2e": "cypress run",
    "e2e:open": "cypress open",
    "e2e:pw": "playwright test",
    "e2e:pw:ui": "playwright test --ui",
    "e2e:pw:headed": "playwright test --headed",
    "e2e:pw:report": "playwright show-report"
  },
  "private": true,
  "packageManager": "npm@11.9.0",
  "dependencies": {
    "@angular/animations": "^21.2.2",
    "@angular/cdk": "^21.2.2",
    "@angular/common": "^21.2.2",
    "@angular/compiler": "^21.2.2",
    "@angular/core": "^21.2.2",
    "@angular/forms": "^21.2.2",
    "@angular/material": "^21.2.2",
    "@angular/platform-browser": "^21.2.2",
    "@angular/router": "^21.2.2",
    "@ngrx/effects": "^21.1.0",
    "@ngrx/entity": "^21.1.0",
    "@ngrx/store": "^21.1.0",
    "@ngrx/store-devtools": "^21.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-devkit/architect": "^0.2102.0",
    "@angular-devkit/build-angular": "^21.2.2",
    "@angular-devkit/core": "^21.2.2",
    "@angular/build": "^21.2.2",
    "@angular/cli": "^21.2.2",
    "@angular/compiler-cli": "^21.2.2",
    "@angular/platform-browser-dynamic": "21.2.2",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-a11y": "^10.2.19",
    "@storybook/addon-docs": "^10.2.19",
    "@storybook/addon-onboarding": "^10.2.19",
    "@storybook/angular": "^10.2.19",
    "@testing-library/dom": "^10.4.1",
    "@types/jest": "^30.0.0",
    "angular-eslint": "21.3.0",
    "cypress": "^15.13.0",
    "eslint": "^10.0.2",
    "eslint-plugin-import-x": "^4.12.2",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-storybook": "^10.2.19",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-preset-angular": "^16.1.1",
    "jsdom": "^28.0.0",
    "ng-mocks": "^14.15.2",
    "prettier": "^3.8.1",
    "storybook": "^10.2.19",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.56.1"
  },
  "overrides": {
    "eslint-plugin-promise": {
      "eslint": "$eslint"
    }
  }
}
